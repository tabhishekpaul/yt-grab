{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT Grab",
  "version": "0.1.0",
  "identifier": "com.ytgrab.app",
  "build": {
    "beforeDevCommand": "node scripts/fetch-ytdlp.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/fetch-ytdlp.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YT Grab",
        "width": 880,
        "height": 920,
        "minWidth": 560,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost https: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["engine/ytdlp-engine.*", "engine/ytdlp-engine.version"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Video & audio downloader",
    "longDescription": "Cross-platform video and audio downloader with presets and advanced options, powered by yt-dlp."
  }
}
